# Local Supabase project overrides (optional — fall back to the values in
# utils/supabase/info.tsx when not set)
# VITE_SUPABASE_PROJECT_ID=
# VITE_SUPABASE_ANON_KEY=

# When set to "true", the app auto-creates an in-memory "default-admin"
# session on first load so you can click around without signing in. This is
# intended for local dev/demo only — leave it unset in pilot and production
# builds so users land on /login.
# VITE_ENABLE_DEFAULT_ADMIN=true
